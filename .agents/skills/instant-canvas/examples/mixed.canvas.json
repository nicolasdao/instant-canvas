{
	"instantcanvas": 1,
	"title": "Deploy configuration",
	"blocks": [
		{
			"type": "markdown",
			"text": "## Configure the deployment\nReview the notes below, then fill in the deployment settings. Values are written to `deploy.config.json` in this workspace — **not** into the chat."
		},
		{
			"type": "form",
			"title": "Deployment settings",
			"destination": { "kind": "json", "path": "deploy.config.json", "mode": "merge" },
			"submitLabel": "Save configuration",
			"fields": [
				{ "name": "region", "label": "Region", "type": "radio", "options": ["us-east-1", "eu-west-1", "ap-southeast-2"], "default": "ap-southeast-2", "required": true },
				{ "name": "instances", "label": "Instance count", "type": "range", "validation": { "min": 1, "max": 12, "step": 1 }, "default": 2 },
				{ "name": "notifyEmail", "label": "Alert email", "type": "email", "required": true, "placeholder": "ops@example.com", "help": "Format check only — deliverability is not verified." },
				{ "name": "features", "label": "Feature flags", "type": "checkboxGroup", "options": ["cdn", "auto-scaling", "blue-green"], "default": ["cdn"] },
				{ "name": "dryRun", "label": "Dry-run first", "type": "checkbox", "default": "true" }
			]
		}
	]
}
